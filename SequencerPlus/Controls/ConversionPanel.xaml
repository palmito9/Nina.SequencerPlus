<UserControl x:Class="NINA.Plugin.SequencerPlus.Controls.ConversionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300"
             x:Name="root">
    <UserControl.Resources>
        <Style x:Key="OptionButtonStyle" TargetType="Button" BasedOn="{StaticResource StandardButton}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
        </Style>

        <Style x:Key="OptionBoxTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource StandardTextBlock}">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="FontSize" Value="10pt"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SummaryItemStyle" TargetType="TextBlock" BasedOn="{StaticResource StandardTextBlock}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <StackPanel Orientation="Vertical" Margin="6">
            <TextBlock Text="{Binding ElementName=root, Path=Title}" TextDecorations="None"  Style="{StaticResource OptionBoxTitleStyle}"/>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                <Button Content="File(s)"
                        Command="{Binding ElementName=root, Path=FileCommand}"
                        Style="{StaticResource OptionButtonStyle}"/>
                <Button Content="Folder"
                        Command="{Binding ElementName=root, Path=FolderCommand}"
                        Style="{StaticResource OptionButtonStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,4">
                <Label>Subfolders</Label>
                <CheckBox IsChecked="{Binding ElementName=root, Path=Recursive}"
                          HorizontalAlignment="Center" Margin="0,0,0,8"/>
            </StackPanel>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,4"/>
            <Grid>
                <ProgressBar Value="{Binding ElementName=root, Path=Progress}" Minimum="0" Maximum="100" Height="15"
                             Visibility="{Binding ElementName=root, Path=ProgressVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                             Margin="0,0,0,4"
                             />
                <TextBlock Text="Converting..."
                            Visibility="{Binding ElementName=root, Path=ProgressVisible, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"
                            TextWrapping="Wrap" TextAlignment="Center"
                            FontSize="10"
                           />
            </Grid>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource SummaryItemStyle}" Visibility="{Binding ElementName=root, Path=HasConverted, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                        <Run Text="✅"/>
                        <Run Text="{Binding ElementName=root, Path=Converted, Mode=OneWay}"/>
                        <Run Text="converted"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource SummaryItemStyle}" Visibility="{Binding ElementName=root, Path=HasSkipped, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                        <Run Text="⏩"/>
                        <Run Text="{Binding ElementName=root, Path=Skipped, Mode=OneWay}"/>
                        <Run Text="unchanged"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="2" Style="{StaticResource SummaryItemStyle}" HorizontalAlignment="Right" Visibility="{Binding ElementName=root, Path=HasError, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                    <Run Text="⚠️"/>
                    <Run Text="{Binding ElementName=root, Path=ErrorCount, Mode=OneWay}"/>
                    <Run Text="error(s)"/>
                </TextBlock>
            </Grid>
            <TextBlock Text="Errors:" FontSize="11" FontWeight="Bold" Margin="0,8,0,2"
                       Visibility="{Binding ElementName=root, Path=HasError, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}"/>
            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding ElementName=root, Path=HasError, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}">
                <ItemsControl ItemsSource="{Binding ElementName=root, Path=Errors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ErrorTextBorder" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1">
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Opacity="0.7"
                                           Margin="2"/>
                            </Border>
                          <DataTemplate.Triggers>
                              <DataTrigger Binding="{Binding RelativeSource={RelativeSource PreviousData}}" Value="{x:Null}">
                                  <Setter TargetName="ErrorTextBorder" Property="BorderThickness" Value="1" />
                              </DataTrigger>
                          </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
